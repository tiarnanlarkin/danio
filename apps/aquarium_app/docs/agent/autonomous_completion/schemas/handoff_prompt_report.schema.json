{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danio.local/schemas/handoff_prompt_report.schema.json",
  "title": "Danio autonomous handoff prompt report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "schema_version",
    "prompt_kind",
    "generated_at_utc",
    "accepted",
    "code",
    "observed_state_mode",
    "state_mode",
    "title",
    "marker",
    "prompt",
    "runner_compatible",
    "explicit_launch_task_capable",
    "automatic_successor_capable",
    "mutations_performed",
    "checks"
  ],
  "properties": {
    "document_type": { "const": "danio_handoff_prompt_report" },
    "schema_version": { "const": 1 },
    "prompt_kind": { "type": "string", "enum": ["Launch", "Successor"] },
    "generated_at_utc": { "$ref": "#/$defs/strict_utc" },
    "accepted": { "type": "boolean" },
    "code": { "$ref": "#/$defs/code" },
    "observed_state_mode": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/mode" }
      ]
    },
    "state_mode": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "enum": ["ready", "handoff_ready"] }
      ]
    },
    "title": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "marker": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+/(?:launch/0|[0-9]+)$"
        }
      ]
    },
    "prompt": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "runner_compatible": { "type": "boolean" },
    "explicit_launch_task_capable": { "type": "boolean" },
    "automatic_successor_capable": { "type": "boolean" },
    "mutations_performed": { "const": false },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" },
      "minItems": 1
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["accepted"],
        "properties": { "accepted": { "const": true } }
      },
      "then": {
        "properties": {
          "code": { "const": "HANDOFF_PROMPT_GENERATED" },
          "observed_state_mode": {
            "type": "string",
            "enum": ["ready", "handoff_ready"]
          },
          "state_mode": {
            "type": "string",
            "enum": ["ready", "handoff_ready"]
          },
          "title": { "type": "string", "minLength": 1 },
          "marker": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+/(?:launch/0|[1-9][0-9]*)$"
          },
          "prompt": { "type": "string", "minLength": 1 }
        }
      },
      "else": {
        "properties": {
          "accepted": { "const": false },
          "state_mode": { "type": "null" },
          "title": { "type": "null" },
          "marker": { "type": "null" },
          "prompt": { "type": "null" },
          "runner_compatible": { "const": false },
          "explicit_launch_task_capable": { "const": false },
          "automatic_successor_capable": { "const": false },
          "checks": {
            "contains": {
              "required": ["status"],
              "properties": { "status": { "const": "fail" } }
            },
            "minContains": 1
          }
        }
      }
    },
    {
      "if": {
        "required": ["accepted", "prompt_kind"],
        "properties": {
          "accepted": { "const": true },
          "prompt_kind": { "const": "Launch" }
        }
      },
      "then": {
        "properties": {
          "observed_state_mode": { "const": "ready" },
          "state_mode": { "const": "ready" },
          "marker": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*/launch/0$"
          }
        }
      }
    },
    {
      "if": {
        "required": ["accepted", "prompt_kind"],
        "properties": {
          "accepted": { "const": true },
          "prompt_kind": { "const": "Successor" }
        }
      },
      "then": {
        "properties": {
          "observed_state_mode": { "const": "handoff_ready" },
          "state_mode": { "const": "handoff_ready" },
          "marker": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*/[1-9][0-9]*$"
          }
        }
      }
    }
  ],
  "$defs": {
    "mode": {
      "type": "string",
      "enum": [
        "inactive",
        "ready",
        "active",
        "handoff_ready",
        "paused",
        "stopped",
        "finalizing",
        "complete"
      ]
    },
    "strict_utc": {
      "type": "string",
      "format": "date-time",
      "minLength": 28,
      "maxLength": 28,
      "pattern": "^(?:(?:[0-9]{4}-(?:(?:(?:0[13578]|1[02])-(?:0[1-9]|[12][0-9]|3[01]))|(?:(?:0[469]|11)-(?:0[1-9]|[12][0-9]|30))|(?:02-(?:0[1-9]|1[0-9]|2[0-8]))))|(?:(?:(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26]))|(?:(?:0[48]|[2468][048]|[13579][26])00))-02-29))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{7}Z$"
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "task_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "list_threads",
        "read_thread",
        "create_thread.project_target"
      ],
      "properties": {
        "list_threads": { "type": "boolean" },
        "read_thread": { "type": "boolean" },
        "create_thread.project_target": { "type": "boolean" }
      }
    },
    "saved_project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "root"],
      "properties": {
        "project_id": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "root": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "minLength": 4,
              "pattern": "^(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z]:/.+$"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["project_id"],
            "properties": { "project_id": { "type": "null" } }
          },
          "then": {
            "properties": { "root": { "type": "null" } }
          },
          "else": {
            "properties": {
              "project_id": { "type": "string", "minLength": 1 },
              "root": { "type": "string", "minLength": 4 }
            }
          }
        }
      ]
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "status", "detail"],
      "properties": {
        "code": { "$ref": "#/$defs/code" },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "detail": { "type": "string", "minLength": 1 }
      }
    }
  }
}
