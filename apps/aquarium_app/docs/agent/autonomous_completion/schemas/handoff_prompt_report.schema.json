{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danio.local/schemas/handoff_prompt_report.schema.json",
  "title": "Danio autonomous handoff prompt report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "schema_version",
    "prompt_kind",
    "generated_at_utc",
    "state_mode",
    "title",
    "marker",
    "prompt",
    "runner_compatible",
    "explicit_launch_task_capable",
    "automatic_successor_capable",
    "checks"
  ],
  "properties": {
    "document_type": { "const": "danio_handoff_prompt_report" },
    "schema_version": { "const": 1 },
    "prompt_kind": { "type": "string", "enum": ["Launch", "Successor"] },
    "generated_at_utc": { "$ref": "#/$defs/strict_utc" },
    "state_mode": { "type": "string", "enum": ["ready", "handoff_ready"] },
    "title": { "type": "string", "minLength": 1 },
    "marker": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+/(?:launch/0|[0-9]+)$"
    },
    "prompt": { "type": "string", "minLength": 1 },
    "runner_compatible": { "type": "boolean" },
    "explicit_launch_task_capable": { "type": "boolean" },
    "automatic_successor_capable": { "type": "boolean" },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "strict_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{7}Z$"
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "status", "detail"],
      "properties": {
        "code": { "$ref": "#/$defs/code" },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "detail": { "type": "string", "minLength": 1 }
      }
    }
  }
}
