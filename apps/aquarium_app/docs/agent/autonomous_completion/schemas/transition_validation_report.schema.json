{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danio.local/schemas/transition_validation_report.schema.json",
  "title": "Danio state transition validation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "schema_version",
    "source",
    "validated_at_utc",
    "valid",
    "code",
    "details",
    "expected_parent_commit",
    "observed_parent_commit",
    "staged_tree_hash",
    "mutations_performed",
    "checks"
  ],
  "properties": {
    "document_type": { "const": "danio_transition_validation_report" },
    "schema_version": { "const": 1 },
    "source": { "type": "string", "enum": ["Staged", "Committed"] },
    "validated_at_utc": { "$ref": "#/$defs/strict_utc" },
    "valid": { "type": "boolean" },
    "code": { "$ref": "#/$defs/code" },
    "details": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "expected_parent_commit": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/git_oid" }
      ]
    },
    "observed_parent_commit": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/git_oid" }
      ]
    },
    "staged_tree_hash": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/git_oid" }
      ]
    },
    "mutations_performed": { "const": false },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "strict_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{7}Z$"
    },
    "git_oid": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "status", "detail"],
      "properties": {
        "code": { "$ref": "#/$defs/code" },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "detail": { "type": "string", "minLength": 1 }
      }
    }
  }
}
