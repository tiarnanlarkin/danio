{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danio.local/schemas/writer_claim_plan.schema.json",
  "title": "Danio autonomous writer claim plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "schema_version",
    "planned_at_utc",
    "valid",
    "code",
    "details",
    "mutations_performed",
    "run_id",
    "work_unit_id",
    "task_id",
    "expected_state_revision",
    "owner_token_sha256",
    "branch_name",
    "worktree_id",
    "worktree_path",
    "base_commit",
    "state_path",
    "next_run_state"
  ],
  "properties": {
    "document_type": { "const": "danio_writer_claim_plan" },
    "schema_version": { "const": 1 },
    "planned_at_utc": { "$ref": "#/$defs/strict_utc" },
    "valid": { "type": "boolean" },
    "code": { "$ref": "#/$defs/code" },
    "details": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "mutations_performed": { "const": false },
    "run_id": { "$ref": "#/$defs/safe_identifier" },
    "work_unit_id": { "$ref": "#/$defs/safe_identifier" },
    "task_id": { "$ref": "#/$defs/safe_identifier" },
    "expected_state_revision": { "type": "integer", "minimum": 1 },
    "owner_token_sha256": { "$ref": "#/$defs/sha256" },
    "branch_name": {
      "type": "string",
      "pattern": "^autonomy/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+/[0-9a-f]{12}$"
    },
    "worktree_id": { "$ref": "#/$defs/safe_identifier" },
    "worktree_path": { "$ref": "#/$defs/absolute_windows_path" },
    "base_commit": { "$ref": "#/$defs/git_oid" },
    "state_path": {
      "const": "apps/aquarium_app/docs/agent/autonomous_completion/phone_completion_run_state.json"
    },
    "next_run_state": {
      "$ref": "run_state.schema.json"
    }
  },
  "$defs": {
    "strict_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{7}Z$"
    },
    "safe_identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_oid": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "absolute_windows_path": {
      "type": "string",
      "minLength": 4,
      "pattern": "^[A-Za-z]:/(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    }
  }
}
