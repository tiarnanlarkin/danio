{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danio.local/schemas/evidence_manifest.schema.json",
  "title": "Danio autonomous completion evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product_commit",
    "work_unit_id",
    "ledger_row_ids",
    "commands",
    "environment",
    "artifacts",
    "overall_status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "product_commit": { "$ref": "#/$defs/git_oid" },
    "work_unit_id": { "$ref": "#/$defs/safe_identifier" },
    "ledger_row_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DCL-[A-Z0-9]+-[0-9]{3}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/command_result" },
      "minItems": 1
    },
    "environment": { "$ref": "#/$defs/environment" },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "overall_status": { "type": "string", "enum": ["pass", "fail"] }
  },
  "allOf": [
    {
      "if": {
        "required": ["overall_status"],
        "properties": { "overall_status": { "const": "pass" } }
      },
      "then": {
        "properties": {
          "commands": {
            "items": {
              "properties": { "exit_code": { "const": 0 } }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "git_oid": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "safe_identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "strict_utc": {
      "type": "string",
      "format": "date-time",
      "minLength": 28,
      "maxLength": 28,
      "pattern": "^(?:(?:[0-9]{4}-(?:(?:(?:0[13578]|1[02])-(?:0[1-9]|[12][0-9]|3[01]))|(?:(?:0[469]|11)-(?:0[1-9]|[12][0-9]|30))|(?:02-(?:0[1-9]|1[0-9]|2[0-8]))))|(?:(?:(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26]))|(?:(?:0[48]|[2468][048]|[13579][26])00))-02-29))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{7}Z$"
    },
    "command_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "exit_code", "started_at_utc", "completed_at_utc"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "exit_code": { "type": "integer" },
        "started_at_utc": { "$ref": "#/$defs/strict_utc" },
        "completed_at_utc": { "$ref": "#/$defs/strict_utc" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "device_id"],
      "properties": {
        "platform": { "const": "windows" },
        "device_id": { "type": ["string", "null"] }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/repo_path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
