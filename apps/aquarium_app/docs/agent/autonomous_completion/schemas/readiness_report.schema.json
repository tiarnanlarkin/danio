{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danio.local/schemas/readiness_report.schema.json",
  "title": "Danio autonomous readiness report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "schema_version",
    "intent",
    "checked_at_utc",
    "eligible",
    "stop_reason_code",
    "checks"
  ],
  "properties": {
    "document_type": { "const": "danio_readiness_report" },
    "schema_version": { "const": 1 },
    "intent": {
      "type": "string",
      "enum": [
        "Launch",
        "Claim",
        "Closeout",
        "Finalization",
        "AdministrativeSync"
      ]
    },
    "checked_at_utc": { "$ref": "#/$defs/strict_utc" },
    "eligible": { "type": "boolean" },
    "stop_reason_code": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/code" }
      ]
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" },
      "minItems": 1
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["eligible"],
        "properties": { "eligible": { "const": true } }
      },
      "then": {
        "properties": { "stop_reason_code": { "type": "null" } }
      },
      "else": {
        "properties": { "stop_reason_code": { "$ref": "#/$defs/code" } }
      }
    }
  ],
  "$defs": {
    "strict_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{7}Z$"
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "status", "detail"],
      "properties": {
        "code": { "$ref": "#/$defs/code" },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "detail": { "type": "string", "minLength": 1 }
      }
    }
  }
}
