{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://danio.local/schemas/readiness_report.schema.json",
  "title": "Danio autonomous readiness report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "schema_version",
    "intent",
    "checked_at_utc",
    "eligible",
    "stop_reason_code",
    "checks"
  ],
  "properties": {
    "document_type": { "const": "danio_readiness_report" },
    "schema_version": { "const": 1 },
    "intent": {
      "type": "string",
      "enum": [
        "Launch",
        "Claim",
        "Closeout",
        "Finalization",
        "AdministrativeSync"
      ]
    },
    "checked_at_utc": { "$ref": "#/$defs/strict_utc" },
    "eligible": { "type": "boolean" },
    "stop_reason_code": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/code" }
      ]
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" },
      "minItems": 1
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["eligible"],
        "properties": { "eligible": { "const": true } }
      },
      "then": {
        "properties": {
          "stop_reason_code": { "type": "null" },
          "checks": {
            "items": {
              "properties": { "status": { "const": "pass" } }
            }
          }
        }
      },
      "else": {
        "properties": {
          "stop_reason_code": { "$ref": "#/$defs/code" },
          "checks": {
            "contains": {
              "properties": { "status": { "const": "fail" } }
            },
            "minContains": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "strict_utc": {
      "type": "string",
      "format": "date-time",
      "minLength": 28,
      "maxLength": 28,
      "pattern": "^(?:(?:[0-9]{4}-(?:(?:(?:0[13578]|1[02])-(?:0[1-9]|[12][0-9]|3[01]))|(?:(?:0[469]|11)-(?:0[1-9]|[12][0-9]|30))|(?:02-(?:0[1-9]|1[0-9]|2[0-8]))))|(?:(?:(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26]))|(?:(?:0[48]|[2468][048]|[13579][26])00))-02-29))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]\\.[0-9]{7}Z$"
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "status", "detail"],
      "properties": {
        "code": { "$ref": "#/$defs/code" },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "detail": { "type": "string", "minLength": 1 }
      }
    }
  }
}
